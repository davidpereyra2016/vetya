{
  "expo": {
    "name": "vetya",
    "slug": "vetya",
    "scheme": "vetya",
    "version": "1.0.2",
    "jsEngine": "jsc",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icons/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E88E5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vetya.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "VetYa necesita acceso a tu ubicación para mostrarte veterinarios cercanos disponibles para emergencias."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "versionCode": 16,
      "package": "com.vetya.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.FOREGROUND_SERVICE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_API_KEY_HERE"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-maps",
        {
          "mode": "universal"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "cb540aaf-1e99-4772-8d7c-457df269ad59"
      }
    },
    "owner": "davidpereyra"
  }
}
