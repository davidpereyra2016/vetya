<style>
  .admin-mobile-toggle {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 1060;
    width: 3rem;
    height: 3rem;
    border: 0;
    border-radius: 999px;
    display: none;
    align-items: center;
    justify-content: center;
    background: #0d6efd;
    color: #fff;
    box-shadow: 0 1rem 2rem rgba(13, 110, 253, 0.25);
  }

  .admin-sidebar-backdrop {
    position: fixed;
    inset: 0;
    z-index: 1030;
    display: none;
    border: 0;
    opacity: 0;
    pointer-events: none;
    background: rgba(15, 23, 42, 0.45);
    transition: opacity 0.25s ease;
  }

  @media (max-width: 768px) {
    .admin-mobile-toggle,
    .admin-sidebar-backdrop {
      display: inline-flex;
    }

    .admin-sidebar-backdrop {
      display: block;
    }

    .sidebar {
      position: fixed;
      top: 0;
      left: 0;
      z-index: 1040;
      width: min(84vw, 320px);
      height: 100vh;
      min-height: 100vh;
      padding: 1rem 0 2rem;
      overflow-y: auto;
      transform: translateX(-100%);
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    body.admin-sidebar-open .sidebar {
      transform: translateX(0);
      box-shadow: 0 1.5rem 3rem rgba(15, 23, 42, 0.25);
    }

    body.admin-sidebar-open .admin-sidebar-backdrop {
      opacity: 1;
      pointer-events: auto;
    }

    main[class*="col-md-9"] {
      width: 100%;
      max-width: 100%;
      padding-top: 5rem;
    }
  }
</style>

<button
  class="admin-mobile-toggle"
  type="button"
  aria-label="Abrir menu"
  aria-controls="admin-sidebar"
  aria-expanded="false"
>
  <i class="fas fa-bars"></i>
</button>

<button
  class="admin-sidebar-backdrop"
  type="button"
  aria-label="Cerrar menu"
  tabindex="-1"
></button>

<!-- Sidebar -->
<nav id="admin-sidebar" class="col-md-3 col-lg-2 d-md-block bg-primary sidebar">
  <div class="position-sticky pt-3">
    <div class="text-center mb-4">
      <h4 class="text-white">Vetya Admin</h4>
    </div>

    <ul class="nav flex-column">
      <li class="nav-item">
        <a class="nav-link text-white <%= typeof activeMenu !== 'undefined' && activeMenu === 'dashboard' ? 'bg-danger' : '' %>" href="/admin/dashboard">
          <i class="fas fa-tachometer-alt me-2"></i>
          Dashboard
        </a>
      </li>

      <li class="nav-item">
        <a class="nav-link text-white <%= typeof activeMenu !== 'undefined' && activeMenu === 'usuarios' ? 'bg-danger' : '' %>" href="/admin/usuarios">
          <i class="fas fa-users me-2"></i>
          Usuarios
        </a>
      </li>

      <li class="nav-item">
        <a class="nav-link text-white <%= typeof activeMenu !== 'undefined' && activeMenu === 'prestadores' ? 'bg-danger' : '' %>" href="/admin/prestadores">
          <i class="fas fa-user-md me-2"></i>
          Prestadores
        </a>
      </li>

      <li class="nav-item">
        <a class="nav-link text-white <%= typeof activeMenu !== 'undefined' && activeMenu === 'validaciones' ? 'bg-danger' : '' %>" href="/admin/validaciones">
          <i class="fas fa-shield-alt me-2"></i>
          Validaciones
        </a>
      </li>

      <li class="nav-item">
        <a class="nav-link text-white <%= typeof activeMenu !== 'undefined' && activeMenu === 'mascotas' ? 'bg-danger' : '' %>" href="/admin/mascotas">
          <i class="fas fa-paw me-2"></i>
          Mascotas
        </a>
      </li>

      <li class="nav-item">
        <a class="nav-link text-white <%= typeof activeMenu !== 'undefined' && activeMenu === 'servicios' ? 'bg-danger' : '' %>" href="/admin/servicios">
          <i class="fas fa-concierge-bell me-2"></i>
          Servicios
        </a>
      </li>

      <li class="nav-item">
        <a class="nav-link text-white <%= typeof activeMenu !== 'undefined' && activeMenu === 'emergencias' ? 'bg-danger' : '' %>" href="/admin/emergencias">
          <i class="fas fa-ambulance me-2"></i>
          Emergencias
        </a>
      </li>

      <li class="nav-item">
        <a class="nav-link text-white <%= typeof activeMenu !== 'undefined' && activeMenu === 'publicidad' ? 'bg-danger' : '' %>" href="/admin/publicidad">
          <i class="fas fa-bullhorn me-2"></i>
          Publicidad
        </a>
      </li>

      <li class="nav-item mt-5">
        <a class="nav-link text-white" href="/admin/logout">
          <i class="fas fa-sign-out-alt me-2"></i>
          Cerrar Sesion
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  (function () {
    if (window.__vetyaAdminMobileMenuBound) return;
    window.__vetyaAdminMobileMenuBound = true;

    const bindMenu = () => {
      const sidebar = document.querySelector('.sidebar');
      const toggle = document.querySelector('.admin-mobile-toggle');
      const backdrop = document.querySelector('.admin-sidebar-backdrop');
      const links = document.querySelectorAll('.sidebar .nav-link');
      const mobileMediaQuery = window.matchMedia('(max-width: 768px)');

      if (!sidebar || !toggle || !backdrop) return;

      const setOpen = (isOpen) => {
        document.body.classList.toggle('admin-sidebar-open', isOpen);
        toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      };

      toggle.addEventListener('click', function () {
        const willOpen = !document.body.classList.contains('admin-sidebar-open');
        setOpen(willOpen);
      });

      backdrop.addEventListener('click', function () {
        setOpen(false);
      });

      links.forEach((link) => {
        link.addEventListener('click', function () {
          if (mobileMediaQuery.matches) {
            setOpen(false);
          }
        });
      });

      mobileMediaQuery.addEventListener('change', function (event) {
        if (!event.matches) {
          setOpen(false);
        }
      });

      document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
          setOpen(false);
        }
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bindMenu, { once: true });
    } else {
      bindMenu();
    }
  })();
</script>
