<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Detalle de Mascota - Panel Administrativo Vetya</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- DataTables CSS -->
  <link rel="stylesheet" href="https://cdn.datatables.net/1.11.5/css/dataTables.bootstrap5.min.css">
  <style>
    body {
      font-family: 'Nunito', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
      background-color: #f8f9fc;
    }
    .sidebar {
      min-height: 100vh;
      box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15);
    }
    .sidebar .nav-item {
      margin-bottom: 0.5rem;
    }
    .sidebar .nav-link {
      border-radius: 0.35rem;
      margin: 0 0.5rem;
      padding: 0.75rem 1rem;
      transition: all 0.3s;
    }
    .sidebar .nav-link:hover {
      background-color: rgba(255, 255, 255, 0.1);
    }
    .card {
      box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15);
      border: none;
      margin-bottom: 1.5rem;
    }
    .stat-card {
      border-left: 4px solid;
    }
    .stat-card.primary { border-left-color: #4e73df; }
    .stat-card.success { border-left-color: #1cc88a; }
    .stat-card.warning { border-left-color: #f6c23e; }
    .stat-card.danger { border-left-color: #e74a3b; }
    .table th {
      border-top: none;
      font-weight: 600;
      color: #5a5c69;
    }
    .pet-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 2rem;
      border-radius: 10px 10px 0 0;
    }
    .avatar-lg {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      border: 4px solid white;
      object-fit: cover;
    }
    .info-row {
      margin-bottom: 0.75rem;
      padding: 0.75rem;
      background-color: #f8f9fc;
      border-radius: 0.5rem;
    }
    .info-row strong {
      display: block;
      color: #5a5c69;
      font-size: 0.875rem;
      margin-bottom: 0.25rem;
    }
  </style>
</head>
<body>
  <div class="container-fluid">
    <div class="row">
      <% const activeMenu = 'mascotas'; %>
      <%- include('../partials/sidebar') %>
      
      <!-- Main Content -->
      <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
        <!-- Breadcrumb -->
        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
              <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
              <li class="breadcrumb-item"><a href="/admin/mascotas">Mascotas</a></li>
              <li class="breadcrumb-item active" aria-current="page"><%= mascota.nombre %></li>
            </ol>
          </nav>
          <a href="/admin/mascotas" class="btn btn-secondary btn-sm">
            <i class="fas fa-arrow-left me-1"></i> Volver
          </a>
        </div>

        <!-- Pet Header Card -->
        <div class="card">
          <div class="pet-header">
            <div class="row align-items-center">
              <div class="col-auto">
                <% if (mascota.imagen) { %>
                  <img src="<%= mascota.imagen %>" alt="<%= mascota.nombre %>" class="avatar-lg">
                <% } else { %>
                  <div class="avatar-lg bg-white text-primary d-flex align-items-center justify-content-center" style="font-size: 2.5rem; font-weight: bold;">
                    <i class="fas fa-paw"></i>
                  </div>
                <% } %>
              </div>
              <div class="col">
                <h2 class="mb-1"><%= mascota.nombre %></h2>
                <p class="mb-0">
                  <span class="badge bg-light text-dark me-2"><%= mascota.tipo %></span>
                  <% if (mascota.raza) { %>
                    <span class="badge bg-light text-dark me-2"><%= mascota.raza %></span>
                  <% } %>
                  <% if (mascota.genero) { %>
                    <span class="badge bg-light text-dark"><%= mascota.genero %></span>
                  <% } %>
                </p>
                <% if (mascota.propietario) { %>
                  <p class="mb-0 mt-2">
                    <i class="fas fa-user me-2"></i>
                    <strong>Propietario:</strong> <%= mascota.propietario.username || mascota.propietario.nombre %> 
                    (<%= mascota.propietario.email %>)
                  </p>
                <% } %>
              </div>
            </div>
          </div>
          <div class="card-body">
            <div class="row">
              <div class="col-md-6">
                <% if (mascota.edad) { %>
                  <p class="mb-2"><strong>Edad:</strong> <%= mascota.edad %></p>
                <% } %>
                <% if (mascota.peso) { %>
                  <p class="mb-2"><strong>Peso:</strong> <%= mascota.peso %> kg</p>
                <% } %>
                <% if (mascota.color) { %>
                  <p class="mb-2"><strong>Color:</strong> <%= mascota.color %></p>
                <% } %>
              </div>
              <div class="col-md-6">
                <% if (mascota.fechaNacimiento) { %>
                  <p class="mb-2"><strong>Fecha de Nacimiento:</strong> <%= new Date(mascota.fechaNacimiento).toLocaleDateString('es-ES') %></p>
                <% } %>
                <% if (mascota.vacunado !== undefined) { %>
                  <p class="mb-2">
                    <strong>Vacunado:</strong> 
                    <% if (mascota.vacunado) { %>
                      <span class="badge bg-success">Sí</span>
                    <% } else { %>
                      <span class="badge bg-warning">No</span>
                    <% } %>
                  </p>
                <% } %>
                <p class="mb-2"><strong>Registrado:</strong> <%= new Date(mascota.createdAt).toLocaleDateString('es-ES') %></p>
              </div>
            </div>
          </div>
        </div>

        <!-- Statistics Cards -->
        <div class="row">
          <div class="col-xl-3 col-md-6">
            <div class="card stat-card primary">
              <div class="card-body">
                <div class="row">
                  <div class="col">
                    <p class="text-xs text-uppercase text-muted mb-1">Total Citas</p>
                    <h4 class="mb-0"><%= estadisticas.totalCitas %></h4>
                  </div>
                  <div class="col-auto">
                    <i class="fas fa-calendar-check fa-2x text-primary opacity-50"></i>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="col-xl-3 col-md-6">
            <div class="card stat-card success">
              <div class="card-body">
                <div class="row">
                  <div class="col">
                    <p class="text-xs text-uppercase text-muted mb-1">Citas Completadas</p>
                    <h4 class="mb-0"><%= estadisticas.citasCompletadas %></h4>
                  </div>
                  <div class="col-auto">
                    <i class="fas fa-check-circle fa-2x text-success opacity-50"></i>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="col-xl-3 col-md-6">
            <div class="card stat-card danger">
              <div class="card-body">
                <div class="row">
                  <div class="col">
                    <p class="text-xs text-uppercase text-muted mb-1">Total Emergencias</p>
                    <h4 class="mb-0"><%= estadisticas.totalEmergencias %></h4>
                  </div>
                  <div class="col-auto">
                    <i class="fas fa-ambulance fa-2x text-danger opacity-50"></i>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="col-xl-3 col-md-6">
            <div class="card stat-card warning">
              <div class="card-body">
                <div class="row">
                  <div class="col">
                    <p class="text-xs text-uppercase text-muted mb-1">Emergencias Activas</p>
                    <h4 class="mb-0"><%= estadisticas.emergenciasActivas %></h4>
                  </div>
                  <div class="col-auto">
                    <i class="fas fa-exclamation-triangle fa-2x text-warning opacity-50"></i>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Información Adicional -->
        <% if (mascota.necesidadesEspeciales || mascota.historialMedico?.length > 0) { %>
          <div class="card">
            <div class="card-header">
              <h5 class="mb-0"><i class="fas fa-notes-medical me-2"></i>Información Médica</h5>
            </div>
            <div class="card-body">
              <% if (mascota.necesidadesEspeciales) { %>
                <div class="info-row">
                  <strong><i class="fas fa-exclamation-circle text-warning me-1"></i> Necesidades Especiales:</strong>
                  <span><%= mascota.necesidadesEspeciales %></span>
                </div>
              <% } %>
              <% if (mascota.historialMedico && mascota.historialMedico.length > 0) { %>
                <div class="info-row">
                  <strong><i class="fas fa-history text-info me-1"></i> Historial Médico:</strong>
                  <ul class="mt-2 mb-0">
                    <% mascota.historialMedico.forEach(registro => { %>
                      <li>
                        <%= new Date(registro.fecha).toLocaleDateString('es-ES') %> - 
                        <%= registro.tipoVisita %> - <%= registro.descripcion %>
                      </li>
                    <% }); %>
                  </ul>
                </div>
              <% } %>
            </div>
          </div>
        <% } %>

        <!-- Historial de Citas -->
        <div class="card">
          <div class="card-header">
            <h5 class="mb-0"><i class="fas fa-calendar-alt me-2"></i>Historial de Citas (<%= citas.length %>)</h5>
          </div>
          <div class="card-body">
            <% if (citas && citas.length > 0) { %>
              <div class="table-responsive">
                <table class="table table-hover" id="tablaCitas">
                  <thead>
                    <tr>
                      <th>Fecha</th>
                      <th>Hora</th>
                      <th>Prestador</th>
                      <th>Servicio</th>
                      <th>Estado</th>
                      <th>Ubicación</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% citas.forEach(cita => { %>
                      <tr>
                        <td><%= new Date(cita.fecha).toLocaleDateString('es-ES') %></td>
                        <td><%= cita.horaInicio %> - <%= cita.horaFin %></td>
                        <td>
                          <% if (cita.prestador) { %>
                            <div><strong><%= cita.prestador.nombre %></strong></div>
                            <small class="text-muted"><%= cita.prestador.tipo %></small>
                          <% } else { %>
                            <span class="text-muted">Sin prestador</span>
                          <% } %>
                        </td>
                        <td>
                          <% if (cita.servicio) { %>
                            <%= cita.servicio.nombre %>
                            <% if (cita.servicio.precio) { %>
                              <br><small class="text-muted">$<%= cita.servicio.precio %></small>
                            <% } %>
                          <% } else { %>
                            <span class="text-muted">Sin servicio</span>
                          <% } %>
                        </td>
                        <td>
                          <% 
                            let badgeClass = 'secondary';
                            if (cita.estado === 'Confirmada') badgeClass = 'success';
                            else if (cita.estado === 'Pendiente') badgeClass = 'warning';
                            else if (cita.estado === 'Completada') badgeClass = 'primary';
                            else if (cita.estado === 'Cancelada') badgeClass = 'danger';
                          %>
                          <span class="badge bg-<%= badgeClass %>"><%= cita.estado %></span>
                        </td>
                        <td><%= cita.ubicacion || 'No especificada' %></td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            <% } else { %>
              <p class="text-muted text-center py-4">No hay citas registradas para esta mascota.</p>
            <% } %>
          </div>
        </div>

        <!-- Historial de Emergencias -->
        <div class="card">
          <div class="card-header">
            <h5 class="mb-0"><i class="fas fa-ambulance me-2"></i>Historial de Emergencias (<%= emergencias.length %>)</h5>
          </div>
          <div class="card-body">
            <% if (emergencias && emergencias.length > 0) { %>
              <div class="table-responsive">
                <table class="table table-hover" id="tablaEmergencias">
                  <thead>
                    <tr>
                      <th>Fecha/Hora</th>
                      <th>Tipo</th>
                      <th>Urgencia</th>
                      <th>Veterinario</th>
                      <th>Estado</th>
                      <th>Descripción</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% emergencias.forEach(emergencia => { %>
                      <tr>
                        <td><%= new Date(emergencia.fechaSolicitud).toLocaleString('es-ES') %></td>
                        <td><%= emergencia.tipoEmergencia %></td>
                        <td>
                          <% 
                            let urgenciaClass = 'secondary';
                            if (emergencia.nivelUrgencia === 'Alta') urgenciaClass = 'danger';
                            else if (emergencia.nivelUrgencia === 'Media') urgenciaClass = 'warning';
                            else if (emergencia.nivelUrgencia === 'Baja') urgenciaClass = 'info';
                          %>
                          <span class="badge bg-<%= urgenciaClass %>"><%= emergencia.nivelUrgencia %></span>
                        </td>
                        <td>
                          <% if (emergencia.veterinario) { %>
                            <div><strong><%= emergencia.veterinario.nombre %></strong></div>
                            <small class="text-muted"><%= emergencia.veterinario.email %></small>
                          <% } else { %>
                            <span class="text-muted">Sin asignar</span>
                          <% } %>
                        </td>
                        <td>
                          <% 
                            let estadoClass = 'secondary';
                            if (emergencia.estado === 'Atendida') estadoClass = 'success';
                            else if (['Asignada', 'En camino', 'En atención'].includes(emergencia.estado)) estadoClass = 'info';
                            else if (emergencia.estado === 'Cancelada') estadoClass = 'danger';
                          %>
                          <span class="badge bg-<%= estadoClass %>"><%= emergencia.estado %></span>
                        </td>
                        <td><%= emergencia.descripcion %></td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            <% } else { %>
              <p class="text-muted text-center py-4">No hay emergencias registradas para esta mascota.</p>
            <% } %>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

  <!-- jQuery y DataTables -->
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>
  <script src="https://cdn.datatables.net/1.11.5/js/dataTables.bootstrap5.min.js"></script>

  <script>
    $(document).ready(function() {
      const dtConfig = {
        "language": {
          "sProcessing": "Procesando...",
          "sLengthMenu": "Mostrar _MENU_ registros",
          "sZeroRecords": "No se encontraron resultados",
          "sEmptyTable": "Ningún dato disponible en esta tabla",
          "sInfo": "Mostrando registros del _START_ al _END_ de un total de _TOTAL_ registros",
          "sInfoEmpty": "Mostrando registros del 0 al 0 de un total de 0 registros",
          "sInfoFiltered": "(filtrado de un total de _MAX_ registros)",
          "sInfoPostFix": "",
          "sSearch": "Buscar:",
          "sUrl": "",
          "sInfoThousands": ",",
          "sLoadingRecords": "Cargando...",
          "oPaginate": {
            "sFirst": "Primero",
            "sLast": "Último",
            "sNext": "Siguiente",
            "sPrevious": "Anterior"
          },
          "oAria": {
            "sSortAscending": ": Activar para ordenar la columna de manera ascendente",
            "sSortDescending": ": Activar para ordenar la columna de manera descendente"
          }
        },
        "pageLength": 10,
        "order": [[ 0, "desc" ]]
      };

      if ($.fn.DataTable) {
        // Tabla de Citas
        if ($('#tablaCitas').length) {
          $('#tablaCitas').DataTable(dtConfig);
        }
        
        // Tabla de Emergencias
        if ($('#tablaEmergencias').length) {
          $('#tablaEmergencias').DataTable(dtConfig);
        }
      }
    });
  </script>
</body>
</html>
