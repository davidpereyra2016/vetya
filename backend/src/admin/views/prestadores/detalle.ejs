<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Detalle de Prestador - Panel Administrativo Vetya</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- DataTables CSS -->
  <link rel="stylesheet" href="https://cdn.datatables.net/1.11.5/css/dataTables.bootstrap5.min.css">
  <style>
    body {
      font-family: 'Nunito', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
      background-color: #f8f9fc;
    }
    .sidebar {
      min-height: 100vh;
      box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15);
    }
    .sidebar .nav-item {
      margin-bottom: 0.5rem;
    }
    .sidebar .nav-link {
      border-radius: 0.35rem;
      margin: 0 0.5rem;
      padding: 0.75rem 1rem;
      transition: all 0.3s;
    }
    .sidebar .nav-link:hover {
      background-color: rgba(255, 255, 255, 0.1);
    }
    .card {
      box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15);
      border: none;
      margin-bottom: 1.5rem;
    }
    .stat-card {
      border-left: 4px solid;
    }
    .stat-card.primary { border-left-color: #4e73df; }
    .stat-card.success { border-left-color: #1cc88a; }
    .stat-card.info { border-left-color: #36b9cc; }
    .stat-card.warning { border-left-color: #f6c23e; }
    .stat-card.danger { border-left-color: #e74a3b; }
    .table th {
      border-top: none;
      font-weight: 600;
      color: #5a5c69;
    }
    .badge-estado {
      padding: 0.35rem 0.65rem;
      font-size: 0.75rem;
    }
    .prestador-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 2rem;
      border-radius: 10px 10px 0 0;
    }
    .avatar-lg {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      border: 4px solid white;
    }
    .section-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #5a5c69;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid #e3e6f0;
    }
  </style>
</head>
<body>
  <div class="container-fluid">
    <div class="row">
      <% const activeMenu = 'prestadores'; %>
      <%- include('../partials/sidebar') %>
      
      <!-- Main Content -->
      <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
        <!-- Breadcrumb -->
        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
              <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
              <li class="breadcrumb-item"><a href="/admin/prestadores">Prestadores</a></li>
              <li class="breadcrumb-item active" aria-current="page"><%= prestador.nombre %></li>
            </ol>
          </nav>
          <a href="/admin/prestadores" class="btn btn-secondary btn-sm">
            <i class="fas fa-arrow-left me-1"></i> Volver
          </a>
        </div>

        <!-- Prestador Header -->
        <div class="card">
          <div class="prestador-header">
            <div class="row align-items-center">
              <div class="col-auto">
                <% if (prestador.imagen) { %>
                  <img src="<%= prestador.imagen %>" alt="<%= prestador.nombre %>" class="avatar-lg">
                <% } else { %>
                  <div class="avatar-lg bg-white text-primary d-flex align-items-center justify-content-center" style="font-size: 2.5rem; font-weight: bold;">
                    <%= prestador.nombre.charAt(0).toUpperCase() %>
                  </div>
                <% } %>
              </div>
              <div class="col">
                <h2 class="mb-1"><%= prestador.nombre %></h2>
                <p class="mb-0"><i class="fas fa-envelope me-2"></i><%= prestador.email %></p>
                <p class="mb-0"><i class="fas fa-phone me-2"></i><%= prestador.telefono || 'N/A' %></p>
                <p class="mb-0 mt-2">
                  <span class="badge bg-primary me-2"><%= prestador.tipo %></span>
                  <span class="badge <%= prestador.activo ? 'bg-success' : 'bg-danger' %>">
                    <%= prestador.activo ? 'Activo' : 'Inactivo' %>
                  </span>
                </p>
              </div>
            </div>
          </div>
          <div class="card-body">
            <div class="row">
              <div class="col-md-6">
                <p class="mb-2"><strong>Especialidades:</strong> <%= prestador.especialidades && prestador.especialidades.length > 0 ? prestador.especialidades.join(', ') : 'N/A' %></p>
                <p class="mb-2"><strong>Rating:</strong> <%= prestador.rating ? prestador.rating.toFixed(1) : '0' %> ★</p>
              </div>
              <div class="col-md-6">
                <% if (prestador.direccion && prestador.direccion.calle) { %>
                  <p class="mb-2"><strong>Dirección:</strong> <%= prestador.direccion.calle %></p>
                <% } %>
                <p class="mb-2"><strong>Registrado:</strong> <%= new Date(prestador.createdAt).toLocaleDateString('es-ES') %></p>
              </div>
            </div>
          </div>
        </div>

        <!-- Statistics -->
        <div class="row">
          <div class="col-xl-3 col-md-6">
            <div class="card stat-card primary">
              <div class="card-body">
                <div class="row">
                  <div class="col">
                    <p class="text-xs text-uppercase text-muted mb-1">Citas</p>
                    <h4 class="mb-0"><%= estadisticas.totalCitas %></h4>
                  </div>
                  <div class="col-auto">
                    <i class="fas fa-calendar-check fa-2x text-primary opacity-50"></i>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="col-xl-3 col-md-6">
            <div class="card stat-card success">
              <div class="card-body">
                <div class="row">
                  <div class="col">
                    <p class="text-xs text-uppercase text-muted mb-1">Servicios</p>
                    <h4 class="mb-0"><%= estadisticas.totalServicios %></h4>
                  </div>
                  <div class="col-auto">
                    <i class="fas fa-concierge-bell fa-2x text-success opacity-50"></i>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="col-xl-3 col-md-6">
            <div class="card stat-card info">
              <div class="card-body">
                <div class="row">
                  <div class="col">
                    <p class="text-xs text-uppercase text-muted mb-1">Ingresos</p>
                    <h4 class="mb-0">$<%= estadisticas.totalRecibido.toFixed(2) %></h4>
                  </div>
                  <div class="col-auto">
                    <i class="fas fa-dollar-sign fa-2x text-info opacity-50"></i>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="col-xl-3 col-md-6">
            <div class="card stat-card warning">
              <div class="card-body">
                <div class="row">
                  <div class="col">
                    <p class="text-xs text-uppercase text-muted mb-1">Valoración</p>
                    <h4 class="mb-0"><%= estadisticas.promedioCalificaciones %> ★</h4>
                  </div>
                  <div class="col-auto">
                    <i class="fas fa-star fa-2x text-warning opacity-50"></i>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Tabs -->
        <ul class="nav nav-tabs" id="prestadorTabs" role="tablist">
          <li class="nav-item" role="presentation">
            <button class="nav-link active" id="citas-tab" data-bs-toggle="tab" data-bs-target="#citas" type="button" role="tab">
              <i class="fas fa-calendar-check me-1"></i>Citas (<%= citas.length %>)
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="servicios-tab" data-bs-toggle="tab" data-bs-target="#servicios" type="button" role="tab">
              <i class="fas fa-concierge-bell me-1"></i>Servicios (<%= servicios.length %>)
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="valoraciones-tab" data-bs-toggle="tab" data-bs-target="#valoraciones" type="button" role="tab">
              <i class="fas fa-star me-1"></i>Valoraciones (<%= valoraciones.length %>)
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="pagos-tab" data-bs-toggle="tab" data-bs-target="#pagos" type="button" role="tab">
              <i class="fas fa-dollar-sign me-1"></i>Pagos (<%= pagos.length %>)
            </button>
          </li>
        </ul>

        <!-- Tab Content -->
        <div class="tab-content mt-3" id="prestadorTabsContent">
          
          <!-- Citas Tab -->
          <div class="tab-pane fade show active" id="citas" role="tabpanel">
            <div class="card">
              <div class="card-header">
                <h5 class="section-title mb-0"><i class="fas fa-calendar-check me-2"></i>Historial de Citas</h5>
              </div>
              <div class="card-body">
                <% if (citas.length > 0) { %>
                  <div class="table-responsive">
                    <table class="table table-hover" id="tablaCitas">
                      <thead>
                        <tr>
                          <th>Fecha</th>
                          <th>Cliente</th>
                          <th>Mascota</th>
                          <th>Servicio</th>
                          <th>Estado</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% citas.slice(0, 50).forEach(cita => { %>
                          <tr>
                            <td><%= new Date(cita.fecha).toLocaleDateString('es-ES') %></td>
                            <td><%= cita.usuario ? cita.usuario.username : 'N/A' %></td>
                            <td><%= cita.mascota ? cita.mascota.nombre : 'N/A' %></td>
                            <td><%= cita.servicio ? cita.servicio.nombre : 'N/A' %></td>
                            <td>
                              <span class="badge <%= 
                                cita.estado === 'Confirmada' ? 'bg-primary' : 
                                cita.estado === 'Pendiente' ? 'bg-warning' : 
                                cita.estado === 'Completada' ? 'bg-success' : 'bg-danger' %>">
                                <%= cita.estado %>
                              </span>
                            </td>
                          </tr>
                        <% }); %>
                      </tbody>
                    </table>
                  </div>
                <% } else { %>
                  <p class="text-muted text-center py-4">No hay citas registradas</p>
                <% } %>
              </div>
            </div>
          </div>

          <!-- Servicios Tab -->
          <div class="tab-pane fade" id="servicios" role="tabpanel">
            <div class="card">
              <div class="card-header">
                <h5 class="section-title mb-0"><i class="fas fa-concierge-bell me-2"></i>Servicios Ofrecidos</h5>
              </div>
              <div class="card-body">
                <% if (servicios.length > 0) { %>
                  <div class="row">
                    <% servicios.forEach(servicio => { %>
                      <div class="col-md-6 mb-3">
                        <div class="card">
                          <div class="card-body">
                            <h6 class="mb-2"><%= servicio.nombre %></h6>
                            <p class="text-muted small mb-2"><%= servicio.descripcion || 'Sin descripción' %></p>
                            <div class="d-flex justify-content-between">
                              <span class="badge bg-info"><%= servicio.categoria || 'General' %></span>
                              <strong>$<%= servicio.precio || 0 %></strong>
                            </div>
                          </div>
                        </div>
                      </div>
                    <% }); %>
                  </div>
                <% } else { %>
                  <p class="text-muted text-center py-4">No hay servicios registrados</p>
                <% } %>
              </div>
            </div>
          </div>

          <!-- Valoraciones Tab -->
          <div class="tab-pane fade" id="valoraciones" role="tabpanel">
            <div class="card">
              <div class="card-header">
                <h5 class="section-title mb-0"><i class="fas fa-star me-2"></i>Valoraciones Recibidas</h5>
              </div>
              <div class="card-body">
                <% if (valoraciones.length > 0) { %>
                  <% valoraciones.forEach(val => { %>
                    <div class="card mb-3">
                      <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                          <div>
                            <h6 class="mb-1"><%= val.usuario ? val.usuario.username : 'Usuario desconocido' %></h6>
                            <small class="text-muted"><%= new Date(val.createdAt).toLocaleDateString('es-ES') %></small>
                          </div>
                          <div class="text-warning">
                            <% for (let i = 1; i <= 5; i++) { %>
                              <i class="fas fa-star<%= i <= val.calificacion ? '' : '-o' %>"></i>
                            <% } %>
                            <span class="ms-2 text-dark"><%= val.calificacion %>/5</span>
                          </div>
                        </div>
                        <% if (val.comentario) { %>
                          <p class="mb-0"><%= val.comentario %></p>
                        <% } %>
                      </div>
                    </div>
                  <% }); %>
                <% } else { %>
                  <p class="text-muted text-center py-4">No hay valoraciones</p>
                <% } %>
              </div>
            </div>
          </div>

          <!-- Pagos Tab -->
          <div class="tab-pane fade" id="pagos" role="tabpanel">
            <div class="card">
              <div class="card-header">
                <h5 class="section-title mb-0"><i class="fas fa-dollar-sign me-2"></i>Historial de Pagos</h5>
              </div>
              <div class="card-body">
                <% if (pagos.length > 0) { %>
                  <div class="table-responsive">
                    <table class="table table-hover" id="tablaPagos">
                      <thead>
                        <tr>
                          <th>Fecha</th>
                          <th>Monto</th>
                          <th>Cliente</th>
                          <th>Estado</th>
                          <th>Concepto</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% pagos.slice(0, 50).forEach(pago => { %>
                          <tr>
                            <td><%= new Date(pago.createdAt).toLocaleDateString('es-ES') %></td>
                            <td><strong>$<%= pago.monto ? pago.monto.toFixed(2) : '0.00' %></strong></td>
                            <td><%= pago.usuario ? pago.usuario.username : 'N/A' %></td>
                            <td>
                              <span class="badge <%= pago.estado === 'Completado' ? 'bg-success' : 'bg-warning' %>">
                                <%= pago.estado || 'Pendiente' %>
                              </span>
                            </td>
                            <td><%= pago.concepto || 'N/A' %></td>
                          </tr>
                        <% }); %>
                      </tbody>
                    </table>
                  </div>
                <% } else { %>
                  <p class="text-muted text-center py-4">No hay pagos registrados</p>
                <% } %>
              </div>
            </div>
          </div>

        </div>
        
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

  <!-- jQuery y DataTables -->
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>
  <script src="https://cdn.datatables.net/1.11.5/js/dataTables.bootstrap5.min.js"></script>

  <script>
    $(document).ready(function() {
      const dtConfig = {
        "language": {
          "sProcessing": "Procesando...",
          "sLengthMenu": "Mostrar _MENU_ registros",
          "sZeroRecords": "No se encontraron resultados",
          "sEmptyTable": "Ningún dato disponible en esta tabla",
          "sInfo": "Mostrando registros del _START_ al _END_ de un total de _TOTAL_ registros",
          "sInfoEmpty": "Mostrando registros del 0 al 0 de un total de 0 registros",
          "sInfoFiltered": "(filtrado de un total de _MAX_ registros)",
          "sInfoPostFix": "",
          "sSearch": "Buscar:",
          "sUrl": "",
          "sInfoThousands": ",",
          "sLoadingRecords": "Cargando...",
          "oPaginate": {
            "sFirst": "Primero",
            "sLast": "Último",
            "sNext": "Siguiente",
            "sPrevious": "Anterior"
          },
          "oAria": {
            "sSortAscending": ": Activar para ordenar la columna de manera ascendente",
            "sSortDescending": ": Activar para ordenar la columna de manera descendente"
          }
        },
        "pageLength": 10,
        "order": [[ 0, "desc" ]]
      };

      if ($.fn.DataTable) {
        // Tabla de Citas
        if ($('#tablaCitas').length) {
          $('#tablaCitas').DataTable(dtConfig);
        }
        
        // Tabla de Pagos
        if ($('#tablaPagos').length) {
          $('#tablaPagos').DataTable(dtConfig);
        }
      }
    });
  </script>
</body>
</html>