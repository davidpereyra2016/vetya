<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Publicidad - Panel Administrativo Vetya</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="https://cdn.datatables.net/1.11.5/css/dataTables.bootstrap5.min.css">
  <style>
    body { font-family: 'Nunito', Arial, sans-serif; background-color: #f8f9fc; }
    .sidebar { min-height: 100vh; box-shadow: 0 0.15rem 1.75rem 0 rgba(58,59,69,.15); }
    .sidebar .nav-link { border-radius: .35rem; margin: 0 .5rem; padding: .75rem 1rem; }
    .card { box-shadow: 0 0.15rem 1.75rem 0 rgba(58,59,69,.15); border: none; }
    .border-left-primary { border-left: .25rem solid #4e73df !important; }
    .border-left-success { border-left: .25rem solid #1cc88a !important; }
    .border-left-info { border-left: .25rem solid #36b9cc !important; }
    .border-left-warning { border-left: .25rem solid #f6c23e !important; }
    .banner-thumb { width: 55px; height: 35px; object-fit: cover; border-radius: 4px; border: 1px solid #ddd; }
    .thumb-stack { display: flex; gap: 4px; flex-wrap: wrap; }
  </style>
</head>
<body>
  <div class="container-fluid">
    <div class="row">
      <% const activeMenu = 'publicidad'; %>
      <%- include('../partials/sidebar') %>

      <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
          <h1 class="h2"><i class="fas fa-bullhorn me-2 text-primary"></i>Publicidad - Anunciantes y Banners</h1>
          <a href="/admin/publicidad/nueva" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Nueva Suscripción
          </a>
        </div>

        <% if (mensaje) { %>
          <div class="alert alert-success alert-dismissible fade show"><%= mensaje %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>
        <% if (error) { %>
          <div class="alert alert-danger alert-dismissible fade show"><%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>

        <!-- Estadísticas -->
        <div class="row mb-4">
          <div class="col-xl-3 col-md-6 mb-3">
            <div class="card border-left-primary shadow h-100 py-2">
              <div class="card-body">
                <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Anunciantes</div>
                <div class="h5 mb-0 fw-bold"><%= estadisticas.totalAnunciantes %></div>
              </div>
            </div>
          </div>
          <div class="col-xl-3 col-md-6 mb-3">
            <div class="card border-left-info shadow h-100 py-2">
              <div class="card-body">
                <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Campañas</div>
                <div class="h5 mb-0 fw-bold"><%= estadisticas.totalCampanas %></div>
              </div>
            </div>
          </div>
          <div class="col-xl-3 col-md-6 mb-3">
            <div class="card border-left-success shadow h-100 py-2">
              <div class="card-body">
                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Suscripciones Activas</div>
                <div class="h5 mb-0 fw-bold"><%= estadisticas.suscripcionesActivas %> / <%= estadisticas.totalSuscripciones %></div>
              </div>
            </div>
          </div>
          <div class="col-xl-3 col-md-6 mb-3">
            <div class="card border-left-warning shadow h-100 py-2">
              <div class="card-body">
                <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Ingreso Mensual Estimado</div>
                <div class="h5 mb-0 fw-bold">$<%= estadisticas.ingresoMensual.toLocaleString('es-AR') %></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Tabla -->
        <div class="card shadow mb-4">
          <div class="card-header py-3">
            <h6 class="m-0 fw-bold text-primary">Listado de Suscripciones Publicitarias</h6>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-hover table-bordered" id="dataTable">
                <thead>
                  <tr>
                    <th>Anunciante / Negocio</th>
                    <th>Campaña</th>
                    <th>Banners</th>
                    <th>Cuota</th>
                    <th>Período</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (suscripciones && suscripciones.length > 0) { %>
                    <% suscripciones.forEach(s => { %>
                      <tr>
                        <td>
                          <% if (s.anunciante) { %>
                            <div class="fw-bold"><%= s.anunciante.nombreNegocio %></div>
                            <small class="text-muted"><%= s.anunciante.nombre %> <%= s.anunciante.apellido %></small><br>
                            <small class="text-muted"><i class="fas fa-phone me-1"></i><%= s.anunciante.telefono %></small>
                          <% } else { %>
                            <span class="text-muted">—</span>
                          <% } %>
                        </td>
                        <td>
                          <% if (s.campana) { %>
                            <div><%= s.campana.titulo || 'Sin título' %></div>
                            <small class="text-muted">Límite: <%= s.campana.limiteBanners %></small>
                          <% } else { %>
                            <span class="text-muted">—</span>
                          <% } %>
                        </td>
                        <td>
                          <% const bns = s.campana && s.campana.banners ? s.campana.banners : []; %>
                          <% if (bns.length > 0) { %>
                            <div class="thumb-stack">
                              <% bns.slice(0, 4).forEach(b => { %>
                                <img src="<%= b.urlImagen %>" class="banner-thumb" alt="banner">
                              <% }); %>
                              <% if (bns.length > 4) { %>
                                <span class="badge bg-secondary align-self-center">+<%= bns.length - 4 %></span>
                              <% } %>
                            </div>
                          <% } else { %>
                            <span class="text-muted small">Sin banners</span>
                          <% } %>
                        </td>
                        <td><strong>$<%= (s.cuotaMensual || 0).toLocaleString('es-AR') %></strong>/mes</td>
                        <td>
                          <small>
                            <%= new Date(s.fechaInicio).toLocaleDateString('es-AR') %><br>
                            <i class="fas fa-arrow-down text-muted"></i><br>
                            <%= new Date(s.fechaFin).toLocaleDateString('es-AR') %>
                          </small>
                        </td>
                        <td>
                          <% 
                            const estadoClase = {
                              'activa': 'bg-success',
                              'pausada': 'bg-warning text-dark',
                              'vencida': 'bg-secondary',
                              'cancelada': 'bg-danger'
                            }[s.estado] || 'bg-secondary';
                          %>
                          <span class="badge <%= estadoClase %>"><%= s.estado %></span>
                        </td>
                        <td>
                          <div class="btn-group btn-group-sm">
                            <a href="/admin/publicidad/<%= s._id %>" class="btn btn-info text-white" title="Ver"><i class="fas fa-eye"></i></a>
                            <a href="/admin/publicidad/<%= s._id %>/editar" class="btn btn-warning text-white" title="Editar"><i class="fas fa-edit"></i></a>
                            <form action="/admin/publicidad/<%= s._id %>/eliminar" method="POST" class="d-inline" onsubmit="return confirm('¿Eliminar esta suscripción y todos sus banners?');">
                              <button type="submit" class="btn btn-danger" title="Eliminar"><i class="fas fa-trash"></i></button>
                            </form>
                          </div>
                        </td>
                      </tr>
                    <% }); %>
                  <% } else { %>
                    <tr>
                      <td colspan="7" class="text-center text-muted py-5">
                        <i class="fas fa-bullhorn fa-3x mb-3 d-block text-gray-300"></i>
                        No hay suscripciones publicitarias registradas.<br>
                        <a href="/admin/publicidad/nueva" class="btn btn-primary mt-3"><i class="fas fa-plus me-2"></i>Crear la primera</a>
                      </td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>
  <script src="https://cdn.datatables.net/1.11.5/js/dataTables.bootstrap5.min.js"></script>
  <script>
    $(document).ready(function(){
      if ($.fn.DataTable && $('#dataTable tbody tr').length > 1) {
        $('#dataTable').DataTable({
          language: { url: '//cdn.datatables.net/plug-ins/1.11.5/i18n/es-ES.json' },
          order: [[4, 'desc']],
          pageLength: 25,
          columnDefs: [{ orderable: false, targets: [2, 6] }]
        });
      }
    });
  </script>
</body>
</html>
